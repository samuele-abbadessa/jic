{
  "name": "jic-cli",
  "version": "0.1.0",
  "description": "JoyInCloud Development Workflow CLI - Multi-module project management for microservices",
  "main": "src/index.js",
  "bin": {
    "jic": "./bin/jic.js"
  },
  "type": "module",
  "scripts": {
    "start": "node bin/jic.js",
    "dev": "node --watch bin/jic.js",
    "test": "node --test src/**/*.test.js",
    "lint": "eslint src/",
    "format": "prettier --write src/",
    "link": "npm link",
    "unlink": "npm unlink -g jic-cli"
  },
  "keywords": [
    "cli",
    "devops",
    "microservices",
    "git",
    "aws",
    "deployment",
    "workflow"
  ],
  "author": "Samuele",
  "license": "MIT",
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ora": "^8.0.1",
    "inquirer": "^9.2.12",
    "execa": "^8.0.1",
    "glob": "^10.3.10",
    "js-yaml": "^4.1.0",
    "table": "^6.8.1",
    "figures": "^6.0.1",
    "log-symbols": "^6.0.0",
    "cli-table3": "^0.6.3",
    "date-fns": "^3.0.6",
    "lodash-es": "^4.17.21",
    "conf": "^12.0.0",
    "semver": "^7.5.4"
  },
  "devDependencies": {
    "eslint": "^8.56.0",
    "prettier": "^3.1.1"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "bin/",
    "src/",
    "schema/"
  ]
}
